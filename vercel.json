{
  "framework": "nextjs",
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/process-dunning",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/pos-sync",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/reconcile-pos",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/pos-offline-check",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/daily-metrics",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/lease-expiry",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/tenant-scores",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/compliance-reminders",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/sla-breach",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/revenue-rollup",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/onboarding-golive",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/onboarding-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/onboarding-escalate",
      "schedule": "0 10 * * *"
    }
  ]
}
